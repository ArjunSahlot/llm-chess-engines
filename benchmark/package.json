    "build": "next build",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.39.8",
    "chess.js": "^1.4.0",
    "lucide-react": "^1.14.0",
    "next": "^15.5.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
