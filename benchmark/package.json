{
  "name": "chessbench-benchmark",
  "version": "0.1.0",
  "private": true,
  "description": "Public benchmark site for ChessBench ELO results and games.",
  "type": "module",
  "scripts": {
    "export:landing": "python3 scripts/export_landing_snapshot.py",
    "predev": "npm run export:landing",
    "dev": "next dev --hostname 0.0.0.0",
